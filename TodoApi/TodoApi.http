@TodoApi_HostAddress = http://localhost:5293

@TenantA = aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
@TenantB = bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb

### Login (returns JWT)
POST {{TodoApi_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "demo@example.com"
}

### Paste token from login response:
@AccessToken = REPLACE_ME

### Login as admin (email must be in Admin:Emails)
POST {{TodoApi_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@example.com"
}

@AdminAccessToken = REPLACE_ME

@UserId = 11111111-1111-1111-1111-111111111111

### List tenant lists (TenantA)
GET {{TodoApi_HostAddress}}/api/lists
Authorization: Bearer {{AccessToken}}
X-Tenant-Id: {{TenantA}}
Accept: application/json

### Create list in TenantA
POST {{TodoApi_HostAddress}}/api/lists
Authorization: Bearer {{AccessToken}}
X-Tenant-Id: {{TenantA}}
Content-Type: application/json

{
  "name": "Personal"
}

### Update list (TenantA)
@ListId = REPLACE_ME
PUT {{TodoApi_HostAddress}}/api/lists/{{ListId}}
Authorization: Bearer {{AccessToken}}
X-Tenant-Id: {{TenantA}}
Content-Type: application/json

{
  "name": "Renamed"
}

### Delete list (TenantA)
DELETE {{TodoApi_HostAddress}}/api/lists/{{ListId}}
Authorization: Bearer {{AccessToken}}
X-Tenant-Id: {{TenantA}}

### Admin: list all lists (all tenants)
GET {{TodoApi_HostAddress}}/api/admin/lists
Authorization: Bearer {{AdminAccessToken}}
Accept: application/json

### Admin: create list for TenantB
POST {{TodoApi_HostAddress}}/api/admin/lists
Authorization: Bearer {{AdminAccessToken}}
Content-Type: application/json

{
  "tenantId": "{{TenantB}}",
  "name": "TenantB list"
}
